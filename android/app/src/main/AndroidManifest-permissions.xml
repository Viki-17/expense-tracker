<?xml version="1.0" encoding="utf-8"?>
<!--
  Add these permissions inside the <manifest> tag in your AndroidManifest.xml
  (located at android/app/src/main/AndroidManifest.xml after running 'npx cap add android')
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Required for reading SMS inbox -->
    <uses-permission android:name="android.permission.READ_SMS" />

    <!-- Required for network access during development -->
    <uses-permission android:name="android.permission.INTERNET" />

</manifest>
