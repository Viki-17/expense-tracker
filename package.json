{
  "name": "expense-tracker-pwa",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-icons.mjs && tsc -b && vite build",
    "build:web": "export VITE_ROUTER_BASE=/expense-tracker && node scripts/generate-icons.mjs && tsc -b && vite build",
    "build:cap": "export VITE_NO_PWA=true && node scripts/generate-icons.mjs && tsc -b && vite build",
    "preview": "vite preview",
    "preview:web": "export VITE_BASE=/expense-tracker/ && vite preview",
    "cap:init": "export JAVA_HOME=/opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home && npx cap init",
    "cap:add:android": "export JAVA_HOME=/opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home && npx cap add android",
    "cap:sync": "npm run build:cap && export JAVA_HOME=/opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home && npx cap sync",
    "cap:sync:web": "npm run build:web && export JAVA_HOME=/opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home && npx cap sync",
    "cap:open:android": "export JAVA_HOME=/opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home && npx cap open android",
    "cap:run:android": "export JAVA_HOME=/opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home && npx cap run android",
    "build:android": "npm run cap:sync && cd android && export JAVA_HOME=/opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home && ./gradlew clean assembleDebug",
    "seed-sms": "bash scripts/seed-sms.sh",
    "android:preview": "bash scripts/preview-android.sh"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@types/react-window": "^1.8.8",
    "dexie": "^4.0.8",
    "dexie-react-hooks": "^1.1.7",
    "framer-motion": "^12.42.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "react-window": "^1.8.11",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.13",
    "typescript": "~5.6.2",
    "vite": "^5.4.9",
    "vite-plugin-pwa": "^0.20.5",
    "workbox-window": "^7.1.0"
  }
}
